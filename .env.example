# ── Supabase (from supabase.com/dashboard/project/rlzjyniextatlumkcsps/settings/api) ──
NEXT_PUBLIC_SUPABASE_URL=https://rlzjyniextatlumkcsps.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── JWT (run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))") ──
JWT_SECRET=your_64_char_secret_here

# ── Cron protection ──
SYNC_SECRET=your_32_char_secret_here

# ── App URL (set after first Vercel deploy) ──
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Mail SMTP settings ──
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_FROM="Your App <noreply@yourdomain.com>"
